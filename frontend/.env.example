# URL base da API backend
# Em dev: http://localhost:8080
# Em prod: https://api.finbot.seu-dominio.com.br
VITE_API_BASE_URL=http://localhost:8080

# Ligar mock da API (MSW) — só em dev, nunca em prod
# true  → MSW intercepta as chamadas e responde com dados fakes
# false → chamadas vão para VITE_API_BASE_URL de verdade
VITE_USE_MOCK=true
